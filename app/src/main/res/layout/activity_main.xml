<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSettings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:onClick="handleClick"
                android:text="Settings" />

            <View
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnAboutUs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:onClick="handleAboutUs"
                android:text="About Us" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_horizontal"
            android:text="Workplace Monitor Stats"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/accelerometerTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Accelerometer (X, Y, Z)"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/xValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Accel X: 0.0"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/yVlaue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Accel Y: 0.0"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/zValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Accel Z: 0.0"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lightValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="L (Light): 0.0 lx"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/stepsValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="S (Steps): 0"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/micValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="M (Mic peak): 0"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/payloadPreviewValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Payload: X:0.0,Y:0.0,Z:0.0,L:0.0,S:0,M:0"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnStart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:onClick="startPublish"
                android:text="Start" />

            <View
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnStop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:onClick="stopPublish"
                android:text="Stop" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
